NODE_ENV=production
CLIENT_ORIGIN=https://chatresumes.com
APP_BASE_URL=https://api.chatresumes.com
DATABASE_URL=postgresql://appadmin:replace-me@chat-resumes-postgres.example:5432/chat_resumes
SOCKET_PATH=/socket.io
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me
# Optional: annual subscription price. Leave unset to disable the annual plan (monthly still works).
ANNUAL_STRIPE_PRICE_ID=price_replace_me_annual
OPENAI_API_KEY=replace-me