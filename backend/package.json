    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.8.2",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3"
  }
